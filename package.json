{
  "name": "@nbslabs/dotai",
  "version": "3.1.0",
  "description": "One .ai/ folder to rule all AI coding tool configs",
  "bin": {
    "dotai": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run lint && npm run test && npm run build"
  },
  "keywords": [
    "ai",
    "claude",
    "gemini",
    "copilot",
    "antigravity",
    "cli",
    "config",
    "symlink"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nbslabs/dotai-cli"
  },
  "dependencies": {
    "yargs": "^17.7.2",
    "@inquirer/prompts": "^7.2.1",
    "picocolors": "^1.1.1",
    "chokidar": "^4.0.3",
    "ignore": "^6.0.2"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "tsup": "^8.3.6",
    "vitest": "^2.1.8",
    "@types/node": "^18.19.68",
    "@types/yargs": "^17.0.33"
  }
}
